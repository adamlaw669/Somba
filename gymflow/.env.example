# Copy to .env.local and fill in to connect GymFlow to a live Somba instance.
# If SOMBA_API_KEY is empty, GymFlow runs on its built-in local mock instead.
#
# These are read server-side only (by the /api/somba/* proxy routes) — the
# merchant API key is never exposed to the browser.

SOMBA_BASE_URL=https://somba.ddns.net

# Merchant API key (shown once when you create a merchant via POST /v1/merchants).
# Format: sk-somba-<key_id>.<secret>
SOMBA_API_KEY=
