PORT=8000
DATABASE_URL=postgresql://user:password@localhost:5432/somba
PUBLIC_BASE_URL=http://localhost:8000

# Nomba API
NOMBA_API_BASE_URL=https://api.nomba.com
# Sub-account: scopes resource calls (mandates, debits, virtual accounts, verify).
NOMBA_ACCOUNT_ID=
# Parent (main) account: required on /v1/auth/token/issue and /refresh only.
# Falls back to NOMBA_ACCOUNT_ID if unset (single-account setups).
NOMBA_PARENT_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=

# Inbound webhook signature verification (Nomba → Somba)
WEBHOOK_SIGNING_SECRET=

# Message broker (optional — only needed if using Redpanda/Kafka relay)
REDPANDA_BROKERS=localhost:9092
